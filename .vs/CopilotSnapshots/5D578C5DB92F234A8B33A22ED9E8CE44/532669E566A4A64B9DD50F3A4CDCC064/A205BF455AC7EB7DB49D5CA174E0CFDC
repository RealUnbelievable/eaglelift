/* =========================
   BASE RESET FOR EAGLELIFT
   ========================= */

html, body, #root {
  height: 100%;
  margin: 0;
}

/* Theme variables with light-mode defaults.
   Device preference (dark) overrides are applied below via prefers-color-scheme. */
:root {
  font-family: "Trebuchet MS";
  line-height: 1.5;
  font-weight: 400;

  /* LIGHT MODE PALETTE (defaults) */
  --color-bg: #f4f6fb;               /* light page background */
  --color-surface: #ffffff;          /* cards / surfaces */
  --color-text: #072146;             /* deep navy (primary text) */
  --color-muted: #4b6788;            /* muted blue for secondary text */

  /* Button / accent swap: primary -> gold, secondary/accent -> dark blue */
  --color-primary: #ffc627;          /* gold (primary buttons) */
  --color-primary-contrast: #072146; /* navy text on gold */
  --color-primary-dark: #e6b223;     /* darker gold for hover */

  --color-accent: #0b3d91;           /* dark blue (secondary, chips, accents) */
  --color-accent-contrast: #ffffff;  /* white text on navy */

  --color-border: #dbe8ff;           /* subtle blue border */
  --scroll-thumb: #c7d9ff;
  --shadow: rgba(7, 33, 70, 0.06);
  --surface-elev: rgba(11,61,145,0.06);

  /* Error colors */
  --color-error: #d3382a;
  --color-error-bg: rgba(211,56,42,0.08);

  color: var(--color-text);
  background-color: var(--color-bg);

  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

/* DARK MODE: use a dark blue background and adjust text/surface colors.
   This matches user device preference automatically. */
@media (prefers-color-scheme: dark) {
  :root {
    /* DARK MODE PALETTE */
    --color-bg: #04172a;               /* dark blue background */
    --color-surface: #07223a;          /* slightly lighter surface */
    --color-text: #eaf6ff;             /* light text for contrast */
    --color-muted: #9fb8d6;

    /* Keep button color roles swapped: primary = gold, accent = navy */
    --color-primary: #ffc627;          /* gold stands out against dark blue */
    --color-primary-contrast: #041726; /* deep navy text on gold */
    --color-primary-dark: #e0ae1f;

    --color-accent: #0b3d91;           /* navy */
    --color-accent-contrast: #ffffff;  /* white on navy */

    --color-border: rgba(255,255,255,0.06);
    --scroll-thumb: rgba(199,217,255,0.12);
    --shadow: rgba(0,0,0,0.6);
    --surface-elev: rgba(255,198,39,0.04);

    /* Error colors in dark mode */
    --color-error: #ff7b7b;
    --color-error-bg: rgba(255,123,123,0.12);
  }
}

/* Remove flex centering from default Vite */
body {
  margin: 0;
  min-height: 100vh;
  background-color: var(--color-bg);
}

/* Remove default Vite button styling */
button {
  font-family: inherit;
}

/* Remove default link styling */
a {
  text-decoration: none;
  color: inherit;
}