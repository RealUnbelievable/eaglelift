/* =========================
   GLOBAL RESET
   ========================= */

* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
  font-family: "Trebuchet MS", Trebuchet, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
}

body {
  background-color: var(--color-bg);
  color: var(--color-text);
}

/* =========================
   APP CONTAINER
   ========================= */

.app {
  min-height: 100vh;
  padding: 40px;
}

/* Error banner */
.error-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  padding: 10px 12px;
  border-radius: 10px;
  margin-bottom: 12px;
  background: var(--color-error-bg);
  border-left: 4px solid var(--color-error);
  color: var(--color-text);
  font-size: 14px;
}

.error-banner button.dismiss {
  background: transparent;
  border: none;
  color: var(--color-text);
  font-weight: 700;
  cursor: pointer;
  padding: 4px 8px;
  border-radius: 6px;
}

/* =========================
   CLOCK
   ========================= */

.clock {
  position: absolute;
  top: 20px;
  left: 30px;
  font-size: 20px;
  color: var(--color-muted);
  pointer-events: none;
  z-index: 10;
}

.date {
  font-size: 17px;
}

/* =========================
   LOGIN / REGISTER
   ========================= */

.login-screen {
  max-width: 400px;
  margin: 120px auto;
  padding: 40px;
  background: var(--color-surface);
  border-radius: 20px;
  box-shadow: 0 10px 30px var(--shadow);
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.login-screen h1 {
  text-align: center;
  margin-bottom: 10px;
}

input {
  padding: 10px 14px;
  border-radius: 12px;
  border: 1px solid var(--color-border);
  background: var(--color-surface);
  outline: none;
  transition: 0.2s ease;
  color: var(--color-text);
}

input::placeholder {
  color: var(--color-muted);
}

input:focus {
  border-color: var(--color-accent);
  box-shadow: 0 4px 12px var(--surface-elev);
  background: var(--color-surface);
}

/* PRIMARY buttons are now GOLD (swapped) */
button {
  padding: 10px;
  border-radius: 12px;
  border: none;
  cursor: pointer;
  background: var(--color-primary);
  color: var(--color-primary-contrast);
  font-weight: 500;
  transition: 0.15s ease;
  box-shadow: 0 6px 18px rgba(0,0,0,0.06);

  /* touch affordances */
  -webkit-tap-highlight-color: transparent;
  touch-action: manipulation; /* improve responsiveness on touch */
}

button:hover {
  background: var(--color-primary-dark);
}

/* SECONDARY uses NAVY (accent) now */
button.secondary {
  background: var(--color-accent);
  color: var(--color-accent-contrast);
  border: 1px solid rgba(0,0,0,0.03);
  box-shadow: 0 6px 18px rgba(11,61,145,0.06);
}

button.secondary:hover {
  filter: brightness(0.95);
}

/* =========================
   DASHBOARD
   ========================= */

.dashboard {
  max-width: 1000px;
  margin: 0 auto;
}

.dashboard h1 {
  margin-bottom: 20px;
  color: var(--color-muted);
}

.schedule-card {
  background: var(--color-surface);
  padding: 16px;
  border-radius: 16px;
  margin-bottom: 12px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 6px 20px var(--shadow);
  cursor: pointer;
  transition: transform 0.18s ease;
  border-left: 4px solid transparent;
}

/* Spacing for rename/trash actions */
.schedule-actions {
  display: flex;
  gap: 12px;
  align-items: center;
}

.schedule-actions span {
  cursor: pointer;
  padding: 6px;
  border-radius: 8px;
}

/* =========================
   PLANNER PAGE
   ========================= */

.planner-page {
  margin-top: 20px;
}

.planner-title {
  color: var(--color-accent);
}

.planner-layout {
  display: grid;
  grid-template-columns: 280px 1fr;
  gap: 30px;
  margin-top: 20px;
}

/* LEFT PANEL */

.planner-left {
  background: var(--color-surface);
  padding: 20px;
  border-radius: 20px;
  box-shadow: 0 8px 24px var(--shadow);
  max-height: 75vh;
  overflow: hidden;
}

/* Exercise box: contains search, filters, and scrollable list */
.planner-left .exercise-box {
  max-height: 420px;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  padding: 12px;
  border-radius: 12px;
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  margin-top: 8px;
}

/* Search + filter row */
.filter-row {
  display: flex;
  gap: 8px;
  align-items: center;
  margin-bottom: 10px;
}

.exercise-search {
  flex: 1;
  padding: 8px 10px;
  border-radius: 10px;
  border: 1px solid var(--color-border);
  background: var(--color-surface);
  color: var(--color-text);
}

/* Filter button */
.filter-btn {
  padding: 8px 10px;
  border-radius: 10px;
  background: rgba(11,61,145,0.06);
  color: var(--color-accent);
  border: 1px solid rgba(11,61,145,0.08);
  cursor: pointer;
}

/* Filter panel with muscle chips */
.filter-panel {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  padding: 8px 0 12px 0;
  border-bottom: 1px solid var(--color-border);
  margin-bottom: 8px;
}

/* Updated muscle chip styles for better contrast and accessibility */
.muscle-chip {
  padding: 6px 10px;
  border-radius: 999px;
  background: var(--color-surface);
  border: 1px solid rgba(11,61,145,0.06);
  color: var(--color-text);
  cursor: pointer;
  font-size: 13px;
  box-shadow: 0 1px 0 rgba(0,0,0,0.02);
  transition: background 150ms ease, color 150ms ease, transform 120ms;
}

.muscle-chip.selected {
  background: var(--color-primary);
  color: var(--color-primary-contrast);
  border-color: rgba(0,0,0,0.04);
  box-shadow: 0 6px 14px rgba(255,198,39,0.12);
}

/* Keyboard / focus state */
.muscle-chip:focus {
  outline: 3px solid rgba(11,61,145,0.12);
  outline-offset: 2px;
}

/* Exercise groups and tiles */
.planner-left h3 {
  margin-bottom: 12px;
  color: var(--color-muted);
}

.planner-left select {
  width: 100%;
  margin-bottom: 12px;
}

.planner-left h4 {
  margin-top: 12px;
  margin-bottom: 6px;
  font-size: 14px;
  color: var(--color-muted);
}

/* Exercise tile list */
.exercise-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
  margin-top: 8px;
}

.exercise-tile {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: var(--color-surface);
  padding: 8px 10px;
  border-radius: 10px;
  box-shadow: 0 2px 6px var(--shadow);
  gap: 12px;
  border: 1px solid rgba(11,61,145,0.03);
}

.exercise-info {
  display: flex;
  align-items: center;
  gap: 8px;
}

.exercise-name {
  font-size: 14px;
  color: var(--color-text);
}

.exercise-count {
  background: var(--color-primary);
  color: var(--color-primary-contrast);
  padding: 2px 6px;
  border-radius: 8px;
  font-size: 12px;
}

.exercise-actions {
  display: flex;
  gap: 8px;
  align-items: center;
}

.exercise-actions button {
  padding: 6px 10px;
  border-radius: 8px;
  font-size: 13px;
}

/* Secondary buttons inside tiles use navy background */
.planner-left .exercise-tile button.secondary {
  background: var(--color-accent);
  color: var(--color-accent-contrast);
  border: 1px solid rgba(0,0,0,0.04);
}

.no-results {
  padding: 12px;
  color: var(--color-muted);
  font-size: 14px;
  text-align: center;
}

/* RIGHT PANEL */

.planner-right {
  background: var(--color-surface);
  padding: 20px;
  border-radius: 20px;
  box-shadow: 0 8px 24px var(--shadow);
}

.planner-right h3 {
  margin-bottom: 16px;
  color: var(--color-muted);
}

/* =========================
   TABLE
   ========================= */

.planner-table {
  width: 100%;
  border-collapse: collapse;
}

.planner-table th {
  text-align: left;
  padding: 12px;
  font-size: 14px;
  color: var(--color-muted);
  border-bottom: 1px solid var(--color-border);
}

.planner-table td {
  padding: 12px;
  border-bottom: 1px solid rgba(11,61,145,0.03);
}

.planner-table input {
  width: 70px;
  text-align: center;
}

/* =========================
   SCROLLBAR (Clean Look)
   ========================= */

::-webkit-scrollbar {
  width: 6px;
}

::-webkit-scrollbar-thumb {
  background: var(--scroll-thumb);
  border-radius: 10px;
}

/* =========================
   RESPONSIVE
   ========================= */

@media (max-width: 900px) {
  .planner-layout {
    grid-template-columns: 1fr;
  }

  .planner-left {
    max-height: none;
  }
}

/* Mobile-specific adjustments */
@media (max-width: 600px) {
  .clock {
    position: relative;
    top: auto;
    left: auto;
    transform: none;
    text-align: center;
    margin: 8px auto;
    font-size: 18px;
    pointer-events: none;
  }

  .clock .date {
    font-size: 14px;
  }

  .app {
    padding: calc(20px + env(safe-area-inset-top)) 16px 16px;
  }

  .login-screen {
    margin: 20px auto;
    padding: 20px;
  }

  .exercise-tile {
    padding: 12px;
  }

  .exercise-actions button {
    padding: 8px 12px;
    font-size: 14px;
  }

  .filter-panel {
    gap: 6px;
  }
}

/* Only apply hover transforms on devices that actually support hovering */
@media (hover: hover) and (pointer: fine) {
  .schedule-card:hover {
    transform: translateY(-2px);
    border-left-color: var(--color-accent);
  }

  .muscle-chip:hover {
    background: rgba(11,61,145,0.04);
    transform: translateY(-1px);
  }
}

h1, h2, h3, h4 {
  font-weight: 600;
  letter-spacing: 0.5px;
}